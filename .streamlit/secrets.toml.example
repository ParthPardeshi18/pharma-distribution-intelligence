# Example secrets for a hosted deployment (e.g. Streamlit Community Cloud).
# Copy the values you need into the host's "Secrets" panel. This file is a
# template only — the real .streamlit/secrets.toml is gitignored and never committed.

# Override the password salt in production (do NOT keep the committed default).
[auth]
salt = "change-me-to-a-long-random-string"

# Public demo: URL of the ANONYMISED warehouse, published as a GitHub Release asset.
# Already set in config/app_config.yaml → demo.db_url; override here only if needed.
# [demo]
# db_url = "https://github.com/ParthPardeshi18/pharma-distribution-intelligence/releases/download/demo-data-v1/erp_warehouse_shareable.db"

# Optional Claude narrative enhancer (off by default in config/app_config.yaml).
# [anthropic]
# api_key = "sk-ant-..."
