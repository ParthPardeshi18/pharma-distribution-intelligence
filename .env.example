# Copy to .env (gitignored) and adjust locally. No secrets committed.

# Default reporting currency for outputs (INR is always the stored source of truth).
REPORTING_CURRENCY=INR

# Default pipeline mode: internal (real data) | shareable (anonymised)
PIPELINE_MODE=internal

# Path to exchange-rate reference (date-aware). Provided by data/reference/.
EXCHANGE_RATES_PATH=data/reference/exchange_rates.csv
